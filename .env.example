# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  OpenClaw AI Engineering Organization — Environment Variables               ║
# ║  Copy this file to .env and fill in your values.                            ║
# ║  NEVER commit the .env file to version control.                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=openclaw
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=50

# ── Qdrant (Vector Store) ───────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=change-me-qdrant-api-key
QDRANT_COLLECTION_NAME=openclaw_embeddings

# ── LLM Providers ───────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-change-me
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-change-me
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=change-me-google-api-key
GOOGLE_DEFAULT_MODEL=gemini-2.5-pro

# AWS Bedrock (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# ── LiteLLM Proxy ───────────────────────────────────────────────────────────
LITELLM_HOST=localhost
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-litellm-change-me
LITELLM_BASE_URL=http://${LITELLM_HOST}:${LITELLM_PORT}
LITELLM_LOG_LEVEL=INFO

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-256-bit-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# GitHub OAuth (for user login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ── MCP (Model Context Protocol) ────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001
MCP_AUTH_TOKEN=change-me-mcp-auth-token
MCP_MAX_CONCURRENT_TOOLS=10
MCP_TOOL_TIMEOUT_SECONDS=120

# ── Celery / Task Queue ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TASK_TRACK_STARTED=true
CELERY_WORKER_CONCURRENCY=4

# ── Observability — OpenTelemetry ────────────────────────────────────────────
OTEL_SERVICE_NAME=openclaw
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_RESOURCE_ATTRIBUTES=service.name=openclaw,service.version=0.1.0,deployment.environment=development

# ── Observability — Langfuse ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_ENABLED=true
LANGFUSE_FLUSH_AT=10
LANGFUSE_FLUSH_INTERVAL=5

# ── Observability — Prometheus / Grafana ─────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=OpenClaw
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ── Storage (S3-compatible) ─────────────────────────────────────────────────
S3_ENDPOINT_URL=
S3_BUCKET_NAME=openclaw-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Git Integration ─────────────────────────────────────────────────────────
GIT_DEFAULT_BRANCH=main
GIT_CLONE_DEPTH=1
GIT_WORKSPACE_DIR=/tmp/openclaw/workspaces

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_MINUTE=100000
RATE_LIMIT_STRATEGY=sliding_window

# ── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_MCP_ENABLED=true
FEATURE_MULTI_AGENT=true
FEATURE_CODE_EXECUTION_SANDBOX=true
FEATURE_AUTO_PR=false
FEATURE_BILLING=false
